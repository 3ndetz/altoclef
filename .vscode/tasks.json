{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build 1.21",
      "type": "shell",
      "windows": { "command": "gradlew.bat :1.21:build" },
      "linux":   { "command": "./gradlew :1.21:build" },
      "osx":     { "command": "./gradlew :1.21:build" },
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "GitHub Release 1.21",
      "type": "shell",
      "windows": { "command": "gradlew.bat :1.21:build :1.21:githubRelease" },
      "linux":   { "command": "./gradlew :1.21:build :1.21:githubRelease" },
      "osx":     { "command": "./gradlew :1.21:build :1.21:githubRelease" },
      "group": { "kind": "build", "isDefault": true },
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "Run Client (Debug Mode)",
      "type": "shell",
      "windows": { "command": ".\\gradlew :1.21:runClient --debug-jvm" },
      "linux":   { "command": "./gradlew :1.21:runClient --debug-jvm" },
      "osx":     { "command": "./gradlew :1.21:runClient --debug-jvm" },
      "isBackground": true,
      "problemMatcher": {
        "pattern": [{ "regexp": "\\b\\B", "file": 1, "location": 2, "message": 3 }],
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*Listening for transport dt_socket at address.*",
          "endsPattern": "^.*Listening for transport dt_socket at address.*"
        }
      },
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "Clean 1.21",
      "type": "shell",
      "windows": { "command": "gradlew.bat :1.21:clean" },
      "linux":   { "command": "./gradlew :1.21:clean" },
      "osx":     { "command": "./gradlew :1.21:clean" },
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    }
  ]
}
